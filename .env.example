# =============================================================================
# Slackathon — Environment Variables Template
# Copy this file to .env and fill in all values before running docker compose.
# NEVER commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=slackathon
POSTGRES_USER=slackathon
POSTGRES_PASSWORD=changeme_strong_db_password
DATABASE_URL=postgresql://slackathon:changeme_strong_db_password@postgres:5432/slackathon

# --- Node.js API ---
NODE_ENV=development
API_PORT=3001

# JWT secret — use a long random string (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_very_long_jwt_secret_replace_this

# JWT expiry
JWT_EXPIRES_IN=7d

# AES-256 key for encrypting XMPP passwords at rest.
# MUST be exactly 64 hex characters (= 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY=changeme_64_hex_chars_aes_key_replace_this_now_0000000000000000

# --- Prosody XMPP Server ---
XMPP_DOMAIN=serverA.local
XMPP_MUC_DOMAIN=conference.serverA.local

# Prosody admin REST API (internal Docker network URL)
PROSODY_ADMIN_URL=http://prosody:5280
# Prosody admin credentials (must match prosody.cfg.lua admins setting)
PROSODY_ADMIN_USER=admin
PROSODY_ADMIN_PASSWORD=changeme_prosody_admin_password

# --- Nginx ---
# (No secrets needed — Nginx reads config from file)

# --- App ---
# Base URL for mock password reset links logged to console (EC-1)
APP_BASE_URL=http://localhost
