# =============================================================================
# Slackathon — Environment Variables
# Copy this file to .env:  cp .env.example .env
# The defaults below work out-of-the-box for local development.
# For production, replace ALL values with strong random secrets.
# NEVER commit .env to version control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=slackathon
POSTGRES_USER=slackathon
POSTGRES_PASSWORD=slackathon_local_dev_2024
DATABASE_URL=postgresql://slackathon:slackathon_local_dev_2024@postgres:5432/slackathon

# --- Node.js API ---
NODE_ENV=development
API_PORT=3001

# JWT secret — use a long random string (min 64 chars)
# Generate a new one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=a]3Fz9Lm!kQ7xR2wP0vN8bY6cT4eS1dU5gH3jI0oK7mA9nB2pC4qD6rE8sF1tG3uH5iJ7kL9mN0oP2qR4sT6uV8wX0yZ1aB3cD5eF7gH9iJ

# JWT expiry
JWT_EXPIRES_IN=7d

# AES-256 key for encrypting XMPP passwords at rest.
# MUST be exactly 64 hex characters (= 32 bytes).
# Generate a new one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Prosody XMPP Server ---
XMPP_DOMAIN=serverA.local
XMPP_MUC_DOMAIN=conference.serverA.local

# Prosody admin REST API (internal Docker network URL)
PROSODY_ADMIN_URL=http://prosody:5280
# Prosody admin credentials (must match prosody.cfg.lua admins setting)
PROSODY_ADMIN_USER=admin
PROSODY_ADMIN_PASSWORD=prosody_admin_local_2024

# --- Nginx ---
# (No secrets needed — Nginx reads config from file)

# --- App ---
# Base URL as seen by the browser. Change the port if 80 is occupied.
# Common: http://localhost (port 80) or http://localhost:8080
APP_BASE_URL=http://localhost:8080
